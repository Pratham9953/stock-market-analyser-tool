{
  "name": "@fo-scanner/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts",
    "lint": "eslint src --ext .ts,.tsx",
