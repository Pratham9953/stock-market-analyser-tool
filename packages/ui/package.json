  },
  "dependencies": {
    "react": "19.1.0",
    "react-native": "0.81.0",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "vitest": "^3.2.4"
  }
}
